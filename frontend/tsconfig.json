{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - Relaxed for submodule compatibility */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path Aliases */
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "puck-internal/*": ["../packages/webapp-libs/weditor/wwai_puck/packages/core/components/Puck/components/Preview/wwai/*"],
      "liquid-compiler/*": ["../packages/liquid-compiler/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "../packages/webapp-libs/weditor/wwai_puck"
  ]
}