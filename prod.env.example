# =====================================================
# PRODUCTION ENVIRONMENT — Single VM Deployment
# =====================================================
# SECURITY: Never commit prod.env to version control
# Copy this file to prod.env on the VM and fill in all values

# =====================================================
# APP
# =====================================================
ENVIRONMENT=production
ACTIVE_PRODUCT=page_builder
ENV_FILE=prod.env

# =====================================================
# POSTGRESQL
# =====================================================
POSTGRES_USER=pagebuilder
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=pagebuilder
DATABASE_URL=postgresql+asyncpg://pagebuilder:CHANGE_THIS_SECURE_PASSWORD@postgres:5432/pagebuilder

# =====================================================
# MONGODB
# =====================================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
MONGO_URI=mongodb://admin:CHANGE_THIS_SECURE_PASSWORD@mongodb:27017
# Set explicitly to bypass Secret Manager fallback in orchestration service
AGENT_MONGODB_URL=mongodb://admin:CHANGE_THIS_SECURE_PASSWORD@mongodb:27017
AGENT_MONGODB_DATABASE=businesses
mongodb_database=businesses

# =====================================================
# REDIS
# =====================================================
REDIS_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =====================================================
# INTERNAL SERVICE URLS (Docker network names)
# =====================================================
ORCHESTRATION_SERVICE_URL=http://orchestration:8081
NODE_SERVER_URL=http://liquid-compiler:3002

# =====================================================
# AUTH / JWT
# =====================================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
secret_key=CHANGE_THIS_TO_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING_MIN_32_CHARS
algorithm=HS256
access_token_expire_minutes=30
jwt_cookie_name=jwt
reset_token_expire_hours=1

# =====================================================
# APPLICATION DOMAIN
# =====================================================
domain=https://getwordsworth.ai
FRONTEND_URL=https://getwordsworth.ai
redirect_after_login=https://getwordsworth.ai/dashboard

# =====================================================
# GOOGLE OAUTH
# =====================================================
# https://console.cloud.google.com/apis/credentials
# Redirect URI must be: https://getwordsworth.ai/api/auth/google_callback
google_oauth2_client_id=
google_oauth2_secret=
google_oauth2_redirect_uri=https://getwordsworth.ai/api/auth/google_callback

# =====================================================
# STRIPE PAYMENTS
# =====================================================
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Webhook URL to register in Stripe Dashboard:
# https://getwordsworth.ai/api/billing/webhook

STRIPE_PRICE_PB_BASIC=price_live_placeholder
STRIPE_PRICE_PB_CREDITS_100=price_live_placeholder

# =====================================================
# EMAIL
# =====================================================
mailchimp_api_key=your_mailchimp_transactional_key
from_email=noreply@getwordsworth.ai
from_name=Wordsworth AI
support_email=support@getwordsworth.ai

# =====================================================
# AI
# =====================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=

# =====================================================
# AWS (S3 + CloudFront for asset storage)
# =====================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=
CLOUDFRONT_DOMAIN=

# =====================================================
# MISC
# =====================================================
SHUTTERSTOCK_API_TOKEN=
