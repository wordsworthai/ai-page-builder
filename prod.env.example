# =====================================================
# PRODUCTION ENVIRONMENT
# =====================================================
# SECURITY: Never commit prod.env to version control
# Copy to prod.env and replace ALL placeholder values

# Environment
env=production

# =====================================================
# DATABASE (Required)
# =====================================================
db_host=your-db-host.amazonaws.com
db_port=5432
db_database=pagebuilder_prod
db_username=prod_user
db_password=CHANGE_THIS_SECURE_PASSWORD
db_sslmode=require

# =====================================================
# MONGODB (Required for business data storage)
# =====================================================
# Full connection URI (recommended for production):
mongodb_url=mongodb://username:password@your-mongodb-host:27017/
# OR use components:
# mongodb+srv:// for Atlas:
# mongodb_url=mongodb+srv://username:password@cluster.mongodb.net/
# OR use components:
# mongodb_host=your-mongodb-host
# mongodb_port=27017
# mongodb_username=your_mongodb_user
# mongodb_password=CHANGE_THIS_SECURE_PASSWORD
mongodb_database=businesses

# =====================================================
# SECURITY (Required - MUST change)
# =====================================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
secret_key=CHANGE_THIS_TO_SECURE_RANDOM_STRING_MIN_32_CHARS
algorithm=HS256
access_token_expire_minutes=30
jwt_cookie_name=jwt
reset_token_expire_hours=1

# =====================================================
# APPLICATION (Required)
# =====================================================
domain=https://yourdomain.com
redirect_after_login=https://yourdomain.com/dashboard

# =====================================================
# STRIPE PAYMENTS (Required for payments)
# =====================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Page Builder product price IDs (get from Stripe Dashboard → Products)
STRIPE_PRICE_PB_BASIC=price_live_placeholder
STRIPE_PRICE_PB_CREDITS_100=price_live_placeholder

# =====================================================
# EMAIL (Required for auth features)
# =====================================================
# Mailchimp Transactional: https://mandrillapp.com
mailchimp_api_key=your_mailchimp_transactional_key
from_email=noreply@yourdomain.com
from_name=Your Company
support_email=support@yourdomain.com

# =====================================================
# OAUTH (Optional)
# =====================================================
# Google: https://console.cloud.google.com/apis/credentials
google_oauth2_client_id=
google_oauth2_secret=
google_oauth2_redirect_uri=https://yourdomain.com/api/auth/google_callback

SHUTTERSTOCK_API_TOKEN=

# =====================================================
# RAGFLOW (Required for construction proposal product)
# =====================================================
RAGFLOW_BASE_URL=http://your-ragflow-ip:9380
RAGFLOW_API_KEY=ragflow-your-api-key
RAGFLOW_USE_MOCK=false
RAGFLOW_DATASET_IDS=your-dataset-id
OPENAI_MODEL=gpt-4o

# RAGFlow Internal Service Passwords (for ops reference — not used by our app code)
RAGFLOW_OPENSEARCH_PASSWORD=
RAGFLOW_MYSQL_PASSWORD=
RAGFLOW_MINIO_PASSWORD=
RAGFLOW_REDIS_PASSWORD=