# =====================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =====================================================
# Copy this file to local.env and update with your values

# Environment
env=local

# Database
db_username=pagebuilder
db_password=pagebuilder
db_host=localhost
db_port=54323
db_database=pagebuilder
db_sslmode=require

# MongoDB Configuration
mongodb_url=mongodb://localhost:27020
mongodb_host=localhost
mongodb_port=27017
mongodb_username=
mongodb_password=
mongodb_database=businesses

# Agent Orchestration MongoDB (optional - separate store for orchestration artifacts)
# If not set, falls back to the default MongoDB settings above.
AGENT_MONGODB_URL=mongodb://admin:admin123@localhost:27018/
AGENT_MONGODB_DATABASE=scraping_db

# Security (use dev values locally)
secret_key=dev-secret-key-change-in-production
algorithm=HS256
access_token_expire_minutes=10080

# Application URLs
domain=http://localhost:5173
BACKEND_URL=http://localhost:8020
redirect_after_login=http://localhost:5173/dashboard

# Google OAuth (optional for local dev)
google_oauth2_client_id=
google_oauth2_secret=
google_oauth2_redirect_uri=http://localhost:8020/api/auth/google_callback

# Stripe Payments (use test keys)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret

# Page Builder product price IDs (get from Stripe Dashboard → Products)
STRIPE_PRICE_PB_BASIC=price_test_placeholder
STRIPE_PRICE_PB_CREDITS_100=price_test_placeholder

# Email (optional for local dev)
mailchimp_api_key=
from_email=noreply@localhost
from_name=Page Builder Dev
support_email=support@localhost

# SHUTTERSTOCK_API_TOKEN=

# =====================================================
# RAGFLOW (Optional — only if using RAGFlow for retrieval)
# =====================================================
# RAGFLOW_BASE_URL=http://localhost:9380
# RAGFLOW_API_KEY=ragflow-your-api-key
# RAGFLOW_USE_MOCK=true
# RAGFLOW_DATASET_IDS=your-dataset-id
# OPENAI_MODEL=gpt-4o

# =====================================================
# NANGO CONNECTORS (Google Drive OAuth + sync via Nango)
# =====================================================
# NANGO_SECRET_KEY=your-nango-secret-key
# NANGO_WEBHOOK_SECRET=your-nango-webhook-secret
# NANGO_BASE_URL=https://api.nango.dev

# RAGFlow Internal Service Passwords (for ops reference — not used by our app code)
# RAGFLOW_OPENSEARCH_PASSWORD=
# RAGFLOW_MYSQL_PASSWORD=
# RAGFLOW_MINIO_PASSWORD=
# RAGFLOW_REDIS_PASSWORD=

# =====================================================
# ORCHESTRATION SERVICE
# =====================================================
# URL of the LangGraph orchestration service (wwai-agent-orchestration)
ORCHESTRATION_SERVICE_URL=http://localhost:8081

# =====================================================
# GOOGLE PLACES / MAPS (optional)
# =====================================================
# VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key
# VITE_SUPPORT_EMAIL=support@example.com

# =====================================================
# GEMINI AI (optional — for image generation features)
# =====================================================
# GEMINI_API_KEY=your-gemini-api-key

# =====================================================
# CORS (optional — override default regex)
# =====================================================
# CORS_ORIGIN_REGEX=https://.*\.yourdomain\.com